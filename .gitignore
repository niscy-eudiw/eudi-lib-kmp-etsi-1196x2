.gradle
**/build/
!src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

.idea
# Ignore Gradle build output directory
build
local.properties
.kotlin

# Ignore iOS distribution frameworks (regenerate using build-ios-distribution.sh)
# Keep the README.md but ignore the generated Frameworks folder
ios-distribution/Frameworks/